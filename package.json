{
  "name": "preferred-markdown-stream",
  "version": "0.1.3",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:playground": "pnpm --filter \"@preferred-markdown-stream/playground\" dev",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release:ci": "node ./scripts/release-packages.mjs",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@jannchie/eslint-config": "^3.7.6",
    "eslint": "^10.2.0",
    "vitepress": "^1.6.4"
  }
}
