{
  "name": "preferred-markdown-stream",
  "version": "0.1.8",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "homepage": "https://github.com/Jannchie/preferred-markdown-stream#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jannchie/preferred-markdown-stream.git"
  },
  "bugs": {
    "url": "https://github.com/Jannchie/preferred-markdown-stream/issues"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev:playground": "pnpm --filter \"@preferred-markdown-stream/playground\" dev",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release:ci": "node ./scripts/release-packages.mjs",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@jannchie/eslint-config": "^3.7.6",
    "@types/node": "^22.18.6",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "vitepress": "^1.6.4",
    "vue-eslint-parser": "^10.4.0"
  }
}
