{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@preferred-markdown-stream/core": ["../core/src/index.ts"],
      "@preferred-markdown-stream/core/*": ["../core/src/*"],
      "@preferred-markdown-stream/vue": ["../vue/src/index.ts"],
      "@preferred-markdown-stream/vue/*": ["../vue/src/*"]
    },
    "types": ["node", "vite/client"]
  },
  "include": [
    "../vue/src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.vue",
    "vite.config.ts"
  ]
}
