{
  "name": "@preferred-markdown-stream/core",
  "type": "module",
  "version": "0.3.0",
  "private": false,
  "homepage": "https://github.com/Jannchie/preferred-markdown-stream/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jannchie/preferred-markdown-stream.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/Jannchie/preferred-markdown-stream/issues"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./streaming-text": {
      "types": "./dist/streamingText.d.ts",
      "import": "./dist/streamingText.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.build.json && node ./scripts/copy-assets.mjs",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc -p ./tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
