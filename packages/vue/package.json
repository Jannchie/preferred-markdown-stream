{
  "name": "@preferred-markdown-stream/vue",
  "type": "module",
  "version": "0.3.0",
  "private": false,
  "homepage": "https://github.com/Jannchie/preferred-markdown-stream/tree/main/packages/vue#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jannchie/preferred-markdown-stream.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/Jannchie/preferred-markdown-stream/issues"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.build.json && node ./scripts/copy-assets.mjs",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc -p ./tsconfig.json"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@preferred-markdown-stream/core": "workspace:^",
    "@shikijs/markdown-it": "^4.0.2",
    "@vueuse/core": "^14.3.0",
    "katex": "^0.16.45",
    "markdown-it": "^14.1.1",
    "markdown-it-texmath": "^1.0.0",
    "markdown-it-todo": "^1.0.5"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "shiki": "^4.0.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vue": "^3.5.34"
  }
}
